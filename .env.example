# ── infra/.env.example ─────────────────────────────────────────────────────
# Copy this file to infra/.env on the EC2 host before the first deploy.
# docker compose automatically loads `infra/.env` and substitutes the values
# into docker-compose.yaml. Never commit the real .env (it is git-ignored).

# ── AWS RDS (MySQL 8.4) ────────────────────────────────────────────────────
# Endpoint shown in the RDS console under "Connectivity & security".
RDS_HOST=gotokart-db.ccjocguqok5t.us-east-1.rds.amazonaws.com
RDS_PORT=3306
RDS_DB_NAME=gotokart
RDS_USERNAME=gotokart_app
RDS_PASSWORD=replace-me-with-a-strong-password

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=GoToKartSuperSecretJwtKey2026!!VeryLongAndSecure@#$%
JWT_EXPIRY_MS=86400000

# ── AWS S3 — product images ────────────────────────────────────────────────
# On EC2 the IAM instance role provides credentials.
# Locally, configure ~/.aws/credentials (e.g. `aws configure --profile gotokart`)
# and run the backend with AWS_PROFILE=gotokart.
AWS_REGION=us-east-1
AWS_S3_BUCKET=gotokart-product-images-035379289330-us-east-1-an
# Optional: CloudFront / custom domain in front of the bucket.
# Leave blank to use https://<bucket>.s3.<region>.amazonaws.com/<key>.
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_PRESIGN_TTL_SECONDS=300

# ── Unsplash (required on EC2) ─────────────────────────────────────────────
# The website napi endpoint returns 401 from AWS. Use the official API instead.
# Create a free app at https://unsplash.com/oauth/applications (50 req/hour).
# Keys that start with "-" must be quoted or docker-compose may mis-parse them.
UNSPLASH_ACCESS_KEY="-your_access_key_here"

# ── Spring Boot local-only override (Option B in docs) ─────────────────────
# Only used when running the JAR directly with `mvn spring-boot:run`. The
# Docker stack reads RDS_* above and constructs the JDBC URL automatically.
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/gotokart?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=your_password

# Local dev only — never commit real keys
# AWS_PROFILE=gotokart

# ── Email (Brevo SMTP) ─────────────────────────────────────────────────────
# Used for login OTP emails to customers and order notifications to admin.
# Create an SMTP key at https://app.brevo.com/settings/keys/smtp
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_login
SMTP_PASS=replace-me-with-brevo-smtp-key
EMAIL_FROM=admin@gotokart.xyz
EMAIL_FROM_NAME=GoToKart
# Where order alerts (placed / shipped / delivered / cancelled) are delivered.
EMAIL_ADMIN=admin@gotokart.xyz
# Used inside admin email bodies as the dashboard link.
ADMIN_URL=https://admin.gotokart.xyz
