# Optional: use when running Spring Boot locally (outside Docker).
# On EC2, `docker-compose.yaml` sets datasource and JWT env vars — this file is not required there.

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/gotokart?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&authenticationPlugin=caching_sha2_password
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_password

# JWT (optional for local runs; match backend defaults if needed)
# JWT_SECRET=
# JWT_EXPIRY_MS=86400000

# AWS S3 — product images
# On EC2 the IAM instance role provides credentials.
# Locally, configure ~/.aws/credentials (e.g. `aws configure --profile gotokart`)
# and run the backend with AWS_PROFILE=gotokart.
AWS_REGION=us-east-1
AWS_S3_BUCKET=gotokart-product-images-035379289330-us-east-1-an
# Optional: CloudFront / custom domain in front of the bucket.
# Leave blank to use https://<bucket>.s3.<region>.amazonaws.com/<key>.
AWS_S3_PUBLIC_BASE_URL=
AWS_S3_PRESIGN_TTL_SECONDS=300

# Local dev only — never commit real keys
# AWS_PROFILE=gotokart
